# Resend API Key - Get yours at https://resend.com
RESEND_API_KEY=RE_XXXXXXXXX

# MercadoPago Access Token - https://www.mercadopago.com.ar/developers/panel
# Para test usar credencial TEST-..., para producción APP_USR-...
MP_ACCESS_TOKEN=APP_USR-XXXXXXXXX

# MercadoPago Webhook Secret - panel MP > tu app > Webhooks > Clave secreta
# Valida la firma HMAC-SHA256 de las notificaciones que llegan a /api/mp-webhook
MP_WEBHOOK_SECRET=XXXXXXXXX

# URL pública del sitio - usada para back_urls y webhook de MercadoPago
# IMPORTANTE: debe ser HTTPS y apuntar al dominio público (no localhost)
PUBLIC_SITE_URL=https://dakodev.com
