---
import Layout from "../layouts/Layout.astro";
import { whatsappLink } from "../lib/whatsapp";

const verticales = [
  {
    key: "erp",
    code: "DAKO・ERP",
    letter: "E",
    accent: "blue",
    tier: "tailored",
    tagline: "Gestión Empresarial Integral",
    audience: "Para Empresas en Crecimiento",
    description:
      "Implementación de Odoo adaptada a tu operación real. Digitalizamos ventas, compras, inventario, contabilidad, manufactura y RRHH en una sola plataforma.",
    features: [
      "Ventas, Compras, Inventario y Contabilidad integrados.",
      "Facturación electrónica (AFIP / normativa local).",
      "Automatización de flujos operativos.",
      "Dashboards de gestión en tiempo real.",
    ],
    aiNote:
      "IA integrada: predicción de demanda, análisis automatizado de datos.",
    payable: false,
  },
  {
    key: "crm",
    code: "DAKO・CRM",
    letter: "C",
    accent: "cyan",
    tier: "express",
    tagline: "Gestión Comercial y Pipeline de Ventas",
    audience: "Para Equipos Comerciales",
    description:
      "Un CRM que tu equipo realmente va a usar. Pipeline visual, seguimientos automáticos y facturación electrónica integrada.",
    features: [
      "Pipeline visual con etapas personalizadas.",
      "Seguimiento automático de oportunidades.",
      "Integración con email y WhatsApp.",
      "Facturación electrónica desde la oportunidad ganada.",
    ],
    aiNote:
      "IA integrada: scoring de leads, sugerencia de próxima acción, análisis de sentimiento.",
    payable: true,
    priceUsd: 300,
    priceLabel: "Empezá ya tu despliegue prioritario",
    priceSubtitle:
      "Usuarios ilimitados • Te contactamos en menos de 24 hs hábiles para coordinar el despliegue",
  },
  {
    key: "dev",
    code: "DAKO・DEV",
    letter: "D",
    accent: "blue",
    tier: "tailored",
    tagline: "Aplicaciones Web a Medida",
    audience: "Para Necesidades Específicas",
    description:
      "Cuando el software del mercado no alcanza, lo construimos. Portales de clientes, plataformas SaaS o integraciones complejas.",
    features: [
      "Portales de autoservicio para clientes.",
      "Plataformas SaaS y sistemas internos.",
      "Integraciones con ERPs y APIs externas.",
      "UX/UI premium con experiencia App-Like.",
    ],
    aiNote:
      "IA integrada: chatbots inteligentes, procesamiento de documentos, IA generativa.",
    payable: false,
  },
  {
    key: "web",
    code: "DAKO・WEB",
    letter: "W",
    accent: "cyan",
    tier: "express",
    tagline: "Landing Pages y Sitios Institucionales",
    audience: "Para Profesionales y PyMEs",
    description:
      "Tu presencia digital profesional, lista para vender desde el primer día. Sitios ultra-rápidos, optimizados para SEO y mobile.",
    features: [
      "Diseño moderno, responsive y optimizado para SEO.",
      "Velocidad de carga instantánea (Astro + Tailwind).",
      "Hosting, SSL y actualizaciones incluidas.",
      "Sin mantenimiento técnico necesario.",
    ],
    aiNote: null,
    payable: true,
    priceUsd: 1,
    priceLabel: "Empezá ya tu desarrollo prioritario",
    priceSubtitle:
      "Te contactamos en menos de 24 hs hábiles",
  },
];

const accentClasses = {
  cyan: {
    text: "text-accent-cyan",
    bg: "bg-accent-cyan",
    bgSoft: "bg-accent-cyan/10",
    border: "border-accent-cyan/50",
    borderSoft: "border-accent-cyan/30",
    shadow: "shadow-accent-cyan/20",
    hover: "hover:border-accent-cyan/50",
    pillBg: "bg-accent-cyan/10",
    pillText: "text-accent-cyan",
  },
  blue: {
    text: "text-accent-blue",
    bg: "bg-accent-blue",
    bgSoft: "bg-accent-blue/10",
    border: "border-accent-blue/50",
    borderSoft: "border-accent-blue/30",
    shadow: "shadow-accent-blue/20",
    hover: "hover:border-accent-blue/50",
    pillBg: "bg-accent-blue/10",
    pillText: "text-accent-blue",
  },
  teal: {
    text: "text-accent-teal",
    bg: "bg-accent-teal",
    bgSoft: "bg-accent-teal/10",
    border: "border-accent-teal/50",
    borderSoft: "border-accent-teal/30",
    shadow: "shadow-accent-teal/20",
    hover: "hover:border-accent-teal/50",
    pillBg: "bg-accent-teal/10",
    pillText: "text-accent-teal",
  },
};

const transversales = [
  {
    title: "Inteligencia Artificial",
    description:
      "IA integrada en cada solución: asistentes conversacionales, análisis predictivo y automatizaciones inteligentes que ayudan a tomar decisiones, no solo a registrar datos.",
    accent: "cyan",
    icon: "ai",
  },
  {
    title: "Automatización de Procesos",
    description:
      "Identificamos tareas repetitivas y las automatizamos: aprobaciones, notificaciones, generación de documentos y sincronizaciones entre sistemas.",
    accent: "blue",
    icon: "automation",
  },
  {
    title: "Facturación Electrónica",
    description:
      "Todos nuestros sistemas incluyen facturación electrónica integrada (AFIP y adaptable a otros países de LATAM). Es parte natural del flujo de trabajo.",
    accent: "teal",
    icon: "invoice",
  },
];
---

<Layout title="Servicios | Dakodev Software Solutions">
  <main class="pt-32 pb-20 relative z-10 overflow-hidden">
    <!-- Decorative parallax orbs -->
    <div
      id="srv-orb-1"
      class="absolute top-[10%] -left-40 w-[500px] h-[500px] bg-accent-cyan/10 rounded-full blur-[100px] z-0 pointer-events-none"
    >
    </div>
    <div
      id="srv-orb-2"
      class="absolute top-[60%] -right-40 w-[600px] h-[600px] bg-accent-teal/10 rounded-full blur-[120px] z-0 pointer-events-none"
    >
    </div>
    <div
      id="srv-orb-3"
      class="absolute bottom-[5%] left-1/3 w-[400px] h-[400px] bg-accent-blue/10 rounded-full blur-[100px] z-0 pointer-events-none"
    >
    </div>

    <div class="container mx-auto px-6 relative z-10">
      <!-- HERO -->
      <div class="max-w-3xl mb-20">
        <div
          id="srv-badge"
          class="text-accent-cyan font-bold tracking-widest uppercase text-sm mb-4 opacity-0 translate-y-6"
        >
          Especialización
        </div>
        <h1
          id="srv-title"
          class="font-heading text-5xl md:text-6xl lg:text-7xl font-bold mb-6 leading-tight opacity-0 translate-y-10"
        >
          Nuestras <span class="text-gradient glow-text">Verticales</span>
        </h1>
        <p
          id="srv-intro"
          class="text-gray-400 text-lg md:text-xl leading-relaxed opacity-0 translate-y-10"
        >
          <span
            class="text-gray-100 font-semibold border-b-2 border-accent-cyan/20"
          >
            Simplificamos lo complejo.
          </span> Desde la presencia digital hasta el núcleo operativo de tu empresa,
          nuestras soluciones están diseñadas para escalar — con IA, automatización
          y facturación electrónica integradas de forma nativa.
        </p>
        <div
          id="srv-hero-line"
          class="h-1 bg-gradient-to-r from-accent-cyan to-accent-blue rounded-full mt-8 w-0"
        >
        </div>
      </div>

      <!-- GRID DE 4 VERTICALES -->
      <div
        class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-32"
      >
        {
          verticales.map((v) => {
            const c = accentClasses[v.accent as keyof typeof accentClasses];
            return (
              <article
                class={`srv-card opacity-0 translate-y-12 glass p-7 md:p-8 rounded-3xl border border-white/5 ${c.hover} transition-all duration-500 group relative overflow-hidden flex flex-col`}
              >
                {/* Letra de fondo */}
                <div class="absolute top-0 right-0 p-3 opacity-10 group-hover:opacity-20 transition-opacity pointer-events-none">
                  <span class={`text-9xl font-black ${c.text} leading-none -mr-4 -mt-4`}>
                    {v.letter}
                  </span>
                </div>

                {/* Ícono */}
                <div
                  class={`w-14 h-14 ${c.bgSoft} rounded-xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300`}
                >
                  {v.key === "erp" && (
                    <svg class={`w-7 h-7 ${c.text}`} fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
                    </svg>
                  )}
                  {v.key === "crm" && (
                    <svg class={`w-7 h-7 ${c.text}`} fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
                    </svg>
                  )}
                  {v.key === "dev" && (
                    <svg class={`w-7 h-7 ${c.text}`} fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
                    </svg>
                  )}
                  {v.key === "web" && (
                    <svg class={`w-7 h-7 ${c.text}`} fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
                    </svg>
                  )}
                </div>

                <h3 class="font-heading text-2xl font-bold mb-1">{v.code}</h3>
                <p class={`text-sm font-medium ${c.text} mb-4`}>{v.tagline}</p>
                <div class="mb-5">
                  <span class={`px-3 py-1 ${c.pillBg} ${c.pillText} rounded-full text-[11px] font-bold uppercase tracking-wide`}>
                    {v.audience}
                  </span>
                </div>

                <p class="text-gray-300 mb-5 text-base leading-relaxed">
                  {v.description}
                </p>

                <ul class="space-y-2.5 text-sm text-gray-400 mb-6 grow">
                  {v.features.map((f) => (
                    <li class="flex items-start">
                      <span class={`${c.text} mr-2 font-bold shrink-0`}>✓</span>
                      <span>{f}</span>
                    </li>
                  ))}
                </ul>

                {v.aiNote && (
                  <div class="mb-6 pt-4 border-t border-white/10">
                    <p class={`text-xs ${c.text} font-medium leading-relaxed`}>
                      ✨ {v.aiNote}
                    </p>
                  </div>
                )}

                {/* Bloque de precio (solo CRM/WEB) */}
                {v.payable && (
                  <div class="mb-6 p-4 rounded-2xl bg-dark/50 border border-white/10">
                    <div class="flex items-baseline gap-2">
                      <span
                        class={`srv-price text-4xl font-black text-gradient leading-none`}
                        data-final={v.priceUsd}
                      >
                        USD ${v.priceUsd}
                      </span>
                    </div>
                    <p class="text-[11px] text-gray-400 uppercase tracking-wider mt-2 font-bold">
                      {v.priceLabel}
                    </p>
                    <p class="text-xs text-gray-500 mt-1">{v.priceSubtitle}</p>
                  </div>
                )}

                {/* CTAs */}
                <div class="flex flex-col gap-2 mt-auto">
                  {v.payable ? (
                    <>
                      <button
                        type="button"
                        data-action="pay"
                        data-product={v.key}
                        data-product-code={v.code}
                        data-price-usd={v.priceUsd}
                        class={`w-full py-3 px-4 ${c.bg} text-dark font-bold rounded-xl hover:bg-white transition-all duration-300 shadow-lg ${c.shadow} inline-flex items-center justify-center gap-2 text-sm`}
                      >
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
                        </svg>
                        Pagar y Reservar
                      </button>
                      <a
                        href={whatsappLink(v.code)}
                        target="_blank"
                        rel="noopener"
                        class={`w-full py-2.5 px-4 border border-white/15 text-white/90 font-medium rounded-xl ${c.hover} hover:text-white transition-all duration-300 inline-flex items-center justify-center gap-2 text-sm`}
                      >
                        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                          <path d="M.057 24l1.687-6.163a11.867 11.867 0 01-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.817 11.817 0 018.413 3.488 11.824 11.824 0 013.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 01-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 001.519 5.273l-.999 3.648 3.969-1.04z"/>
                        </svg>
                        Reservar por WhatsApp
                      </a>
                    </>
                  ) : (
                    <a
                      href={whatsappLink(v.code, "consultar")}
                      target="_blank"
                      rel="noopener"
                      class={`w-full py-3 px-4 ${c.bg} text-dark font-bold rounded-xl hover:bg-white transition-all duration-300 shadow-lg ${c.shadow} inline-flex items-center justify-center gap-2 text-sm`}
                    >
                      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M.057 24l1.687-6.163a11.867 11.867 0 01-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.817 11.817 0 018.413 3.488 11.824 11.824 0 013.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 01-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 001.519 5.273l-.999 3.648 3.969-1.04z"/>
                      </svg>
                      Solicitar Asesoría
                    </a>
                  )}
                </div>
              </article>
            );
          })
        }
      </div>

      <!-- CAPACIDADES TRANSVERSALES -->
      <section
        id="srv-trans-section"
        aria-labelledby="srv-trans-heading"
        class="mb-32"
      >
        <div class="max-w-3xl mb-12">
          <span
            id="srv-trans-badge"
            class="text-accent-cyan font-bold tracking-widest uppercase text-sm mb-4 block opacity-0 translate-y-6"
          >
            Capacidades Transversales
          </span>
          <h2
            id="srv-trans-heading"
            class="font-heading text-4xl md:text-5xl lg:text-6xl font-bold mb-6 leading-tight opacity-0 translate-y-10"
          >
            En el <span class="text-gradient glow-text">ADN</span> de cada solución
          </h2>
          <p
            id="srv-trans-intro"
            class="text-gray-400 text-lg leading-relaxed opacity-0 translate-y-10"
          >
            Estas capacidades no se venden por separado: están integradas en
            nuestras tres verticales principales. Es parte del flujo natural,
            no un agregado externo.
          </p>
          <div
            id="srv-trans-line"
            class="h-1 bg-gradient-to-r from-accent-cyan to-accent-teal rounded-full mt-8 w-0"
          >
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {
            transversales.map((t, i) => {
              const c = accentClasses[t.accent as keyof typeof accentClasses];
              return (
                <div
                  class={`srv-trans-card opacity-0 translate-y-12 glass p-8 rounded-3xl border border-white/5 ${c.hover} transition-all duration-500 group relative`}
                >
                  <div
                    class={`w-14 h-14 ${c.bgSoft} rounded-xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300`}
                  >
                    {t.icon === "ai" && (
                      <svg class={`w-7 h-7 ${c.text}`} fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
                      </svg>
                    )}
                    {t.icon === "automation" && (
                      <svg class={`w-7 h-7 ${c.text}`} fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                      </svg>
                    )}
                    {t.icon === "invoice" && (
                      <svg class={`w-7 h-7 ${c.text}`} fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                      </svg>
                    )}
                  </div>
                  <div class={`text-[11px] font-bold uppercase tracking-widest ${c.text} mb-3`}>
                    0{i + 1}
                  </div>
                  <h3 class="font-heading text-2xl font-bold mb-3">{t.title}</h3>
                  <p class="text-gray-400 leading-relaxed">{t.description}</p>
                </div>
              );
            })
          }
        </div>
      </section>

      <!-- CTA FINAL -->
      <div id="srv-final-cta" class="text-center max-w-2xl mx-auto opacity-0 translate-y-10">
        <h2 class="font-heading text-3xl md:text-5xl font-bold mb-6 leading-tight">
          ¿No estás seguro <span class="text-gradient">qué solución se ajusta a tu negocio</span>?
        </h2>
        <p class="text-gray-400 text-lg mb-8 leading-relaxed">
          Contanos brevemente sobre tu operación actual y te ayudamos a identificar
          el camino que más impacto va a generar. Sin compromiso, en una conversación
          de 15 minutos.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="/contacto/"
            class="px-8 py-4 bg-accent-cyan text-dark font-bold rounded-xl hover:bg-white transition-all duration-300 shadow-lg shadow-accent-cyan/20 inline-flex items-center justify-center"
          >
            Solicitar Asesoría
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-5 w-5 ml-2"
              viewBox="0 0 20 20"
              fill="currentColor"
            >
              <path
                fill-rule="evenodd"
                d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z"
                clip-rule="evenodd"></path>
            </svg>
          </a>
          <a
            href={whatsappLink("una asesoría general", "consultar")}
            target="_blank"
            rel="noopener"
            class="px-8 py-4 border border-white/20 text-white font-medium rounded-xl hover:border-accent-cyan/50 hover:text-accent-cyan transition-all duration-300 inline-flex items-center justify-center gap-2"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M.057 24l1.687-6.163a11.867 11.867 0 01-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.817 11.817 0 018.413 3.488 11.824 11.824 0 013.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 01-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 001.519 5.273l-.999 3.648 3.969-1.04z"/>
            </svg>
            Hablar por WhatsApp
          </a>
        </div>
      </div>
    </div>

    <!-- ===== MODAL DE PAGO ===== -->
    <div
      id="srv-pay-modal"
      class="fixed inset-0 z-[100] hidden items-center justify-center p-4"
      aria-modal="true"
      role="dialog"
      aria-labelledby="srv-pay-title"
    >
      <div
        id="srv-pay-backdrop"
        class="absolute inset-0 bg-dark/80 backdrop-blur-md"
      >
      </div>
      <div
        id="srv-pay-panel"
        class="relative glass max-w-lg w-full rounded-3xl border border-white/10 p-8 md:p-10 z-10"
      >
        <button
          type="button"
          id="srv-pay-close"
          aria-label="Cerrar"
          class="absolute top-4 right-4 w-10 h-10 rounded-full flex items-center justify-center text-gray-400 hover:text-white hover:bg-white/5 transition-colors"
        >
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>

        <span
          id="srv-pay-eyebrow"
          class="text-accent-cyan font-bold tracking-widest uppercase text-xs mb-3 block"
        >
          Reserva Segura
        </span>
        <h3
          id="srv-pay-title"
          class="font-heading text-2xl md:text-3xl font-bold mb-2 leading-tight"
        >
          Reservar <span id="srv-pay-product" class="text-gradient">DAKO</span>
        </h3>
        <p class="text-gray-400 text-sm mb-6 leading-relaxed">
          Completá tus datos y te llevamos al pago seguro de MercadoPago. Tras
          confirmarse, te contactamos en menos de <strong class="text-accent-cyan">24 hs hábiles</strong>.
        </p>

        <form id="srv-pay-form" class="space-y-4">
          <div>
            <label class="block text-xs font-bold uppercase tracking-wider text-gray-400 mb-2">
              Nombre completo
            </label>
            <input
              type="text"
              name="name"
              required
              autocomplete="name"
              class="w-full bg-dark/50 border border-white/10 rounded-xl px-4 py-3 text-white placeholder-gray-500 focus:outline-none focus:border-accent-cyan/60 transition-colors"
              placeholder="Tu nombre y apellido"
            />
          </div>
          <div>
            <label class="block text-xs font-bold uppercase tracking-wider text-gray-400 mb-2">
              Email
            </label>
            <input
              type="email"
              name="email"
              required
              autocomplete="email"
              class="w-full bg-dark/50 border border-white/10 rounded-xl px-4 py-3 text-white placeholder-gray-500 focus:outline-none focus:border-accent-cyan/60 transition-colors"
              placeholder="vos@empresa.com"
            />
          </div>

          <div
            id="srv-pay-summary"
            class="hidden p-4 rounded-2xl bg-dark/60 border border-accent-cyan/20"
          >
          </div>

          <div
            id="srv-pay-error"
            class="hidden p-3 rounded-xl bg-red-500/10 border border-red-500/30 text-red-300 text-sm"
          >
          </div>

          <button
            type="submit"
            id="srv-pay-submit"
            class="w-full py-3.5 px-6 bg-accent-cyan text-dark font-bold rounded-xl hover:bg-white transition-all duration-300 shadow-lg shadow-accent-cyan/20 inline-flex items-center justify-center gap-2 disabled:opacity-50 disabled:cursor-not-allowed"
          >
            <span id="srv-pay-submit-text">Continuar al Pago</span>
            <svg id="srv-pay-spinner" class="hidden animate-spin w-5 h-5" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
          </button>

          <p class="text-[11px] text-gray-500 text-center leading-relaxed">
            Al continuar, aceptás que se procese un pago único de reserva en pesos al
            cambio oficial del día. El monto en USD se convierte automáticamente.
          </p>
        </form>
      </div>
    </div>
  </main>
</Layout>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const initServiciosAnimations = () => {
    if (!document.querySelector("#srv-title")) return;

    // Kill stale ScrollTriggers from this section only
    ScrollTrigger.getAll()
      .filter((st: any) => st.vars?.id?.startsWith("srv-"))
      .forEach((st) => st.kill());

    // ── PARALLAX ORBS ──
    gsap.to("#srv-orb-1", {
      scrollTrigger: { id: "srv-orb1", trigger: "main", start: "top top", end: "bottom top", scrub: 1 },
      y: -200, x: 100, ease: "none",
    });
    gsap.to("#srv-orb-2", {
      scrollTrigger: { id: "srv-orb2", trigger: "main", start: "top top", end: "bottom top", scrub: 1 },
      y: -300, x: -120, ease: "none",
    });
    gsap.to("#srv-orb-3", {
      scrollTrigger: { id: "srv-orb3", trigger: "main", start: "top top", end: "bottom top", scrub: 1 },
      y: -150, x: 80, ease: "none",
    });

    // ── HERO ──
    gsap.to("#srv-badge", {
      scrollTrigger: { id: "srv-badge", trigger: "#srv-badge", start: "top 90%", toggleActions: "play none none reverse" },
      y: 0, opacity: 1, duration: 0.8, ease: "power3.out",
    });
    gsap.to("#srv-title", {
      scrollTrigger: { id: "srv-title", trigger: "#srv-title", start: "top 90%", toggleActions: "play none none reverse" },
      y: 0, opacity: 1, duration: 1.1, delay: 0.1, ease: "power3.out",
    });
    gsap.to("#srv-intro", {
      scrollTrigger: { id: "srv-intro", trigger: "#srv-intro", start: "top 90%", toggleActions: "play none none reverse" },
      y: 0, opacity: 1, duration: 1, delay: 0.3, ease: "power3.out",
    });
    gsap.to("#srv-hero-line", {
      scrollTrigger: { id: "srv-hero-line", trigger: "#srv-hero-line", start: "top 90%", toggleActions: "play none none reverse" },
      width: "40%", duration: 1.4, delay: 0.4, ease: "power2.inOut",
    });

    // ── CARDS DE VERTICALES ──
    gsap.utils.toArray<HTMLElement>(".srv-card").forEach((card, i) => {
      gsap.to(card, {
        scrollTrigger: { id: `srv-card-${i}`, trigger: card, start: "top 88%", toggleActions: "play none none reverse" },
        y: 0, opacity: 1, duration: 0.9, delay: i * 0.12, ease: "back.out(1.5)",
      });
    });

    // ── SCRAMBLE EN PRECIOS ──
    const scrambleChars = "0123456789$%#@!";
    const isStaticChar = (c: string) =>
      c === " " || c === "$" || c === "U" || c === "S" || c === "D";
    const scrambleString = (final: string) =>
      final
        .split("")
        .map((c) =>
          isStaticChar(c)
            ? c
            : scrambleChars[Math.floor(Math.random() * scrambleChars.length)]
        )
        .join("");

    gsap.utils.toArray<HTMLElement>(".srv-price").forEach((el) => {
      const final = (el.dataset.finalText || el.textContent || "").trim();
      el.dataset.finalText = final;

      // Estado inicial scrambled — el precio NO se revela hasta entrar al viewport
      el.textContent = scrambleString(final);
      let activeInterval: number | null = null;

      ScrollTrigger.create({
        id: `srv-scramble-${el.dataset.final}`,
        trigger: el,
        start: "top 92%",
        once: false,
        onEnter: () => {
          if (activeInterval !== null) window.clearInterval(activeInterval);
          let iterations = 0;
          const maxIterations = 28;
          activeInterval = window.setInterval(() => {
            el.textContent = final
              .split("")
              .map((char, idx) => {
                if (isStaticChar(char)) return char;
                if (idx < iterations / (maxIterations / final.length)) {
                  return final[idx];
                }
                return scrambleChars[
                  Math.floor(Math.random() * scrambleChars.length)
                ];
              })
              .join("");
            if (iterations >= maxIterations) {
              if (activeInterval !== null) window.clearInterval(activeInterval);
              activeInterval = null;
              el.textContent = final;
            }
            iterations++;
          }, 1000 / 30);
        },
        onLeaveBack: () => {
          if (activeInterval !== null) {
            window.clearInterval(activeInterval);
            activeInterval = null;
          }
          el.textContent = scrambleString(final);
        },
      });
    });

    // ── SECCIÓN TRANSVERSALES ──
    gsap.to("#srv-trans-badge", {
      scrollTrigger: { id: "srv-trans-badge", trigger: "#srv-trans-badge", start: "top 85%", toggleActions: "play none none reverse" },
      y: 0, opacity: 1, duration: 0.8, ease: "power3.out",
    });
    gsap.to("#srv-trans-heading", {
      scrollTrigger: { id: "srv-trans-h2", trigger: "#srv-trans-heading", start: "top 85%", toggleActions: "play none none reverse" },
      y: 0, opacity: 1, duration: 1.1, delay: 0.1, ease: "power3.out",
    });
    gsap.to("#srv-trans-intro", {
      scrollTrigger: { id: "srv-trans-intro", trigger: "#srv-trans-intro", start: "top 85%", toggleActions: "play none none reverse" },
      y: 0, opacity: 1, duration: 1, delay: 0.3, ease: "power3.out",
    });
    gsap.to("#srv-trans-line", {
      scrollTrigger: { id: "srv-trans-line", trigger: "#srv-trans-line", start: "top 85%", toggleActions: "play none none reverse" },
      width: "100%", duration: 1.5, ease: "power2.inOut",
    });

    gsap.utils.toArray<HTMLElement>(".srv-trans-card").forEach((card, i) => {
      gsap.to(card, {
        scrollTrigger: { id: `srv-trans-card-${i}`, trigger: card, start: "top 88%", toggleActions: "play none none reverse" },
        y: 0, opacity: 1, duration: 0.9, delay: i * 0.15, ease: "back.out(1.5)",
      });
    });

    // ── CTA FINAL ──
    gsap.to("#srv-final-cta", {
      scrollTrigger: { id: "srv-final-cta", trigger: "#srv-final-cta", start: "top 85%", toggleActions: "play none none reverse" },
      y: 0, opacity: 1, duration: 1, ease: "power3.out",
    });
  };

  // ===== MODAL DE PAGO =====
  const initPayModal = () => {
    const modal = document.getElementById("srv-pay-modal");
    const panel = document.getElementById("srv-pay-panel");
    const backdrop = document.getElementById("srv-pay-backdrop");
    const closeBtn = document.getElementById("srv-pay-close");
    const form = document.getElementById("srv-pay-form") as HTMLFormElement | null;
    const submitBtn = document.getElementById("srv-pay-submit") as HTMLButtonElement | null;
    const submitText = document.getElementById("srv-pay-submit-text");
    const spinner = document.getElementById("srv-pay-spinner");
    const productLabel = document.getElementById("srv-pay-product");
    const errorBox = document.getElementById("srv-pay-error");
    const summaryBox = document.getElementById("srv-pay-summary");

    if (!modal || !form || !submitBtn) return;

    let currentProduct: string | null = null;
    let currentProductCode = "";
    let currentPriceUsd = 0;

    const showError = (msg: string) => {
      if (!errorBox) return;
      errorBox.textContent = msg;
      errorBox.classList.remove("hidden");
    };
    const hideError = () => errorBox?.classList.add("hidden");

    const openModal = (product: string, code: string, priceUsd: number) => {
      currentProduct = product;
      currentProductCode = code;
      currentPriceUsd = priceUsd;
      if (productLabel) productLabel.textContent = code;
      hideError();
      summaryBox?.classList.add("hidden");
      form.reset();
      modal.classList.remove("hidden");
      modal.classList.add("flex");
      document.body.style.overflow = "hidden";

      gsap.fromTo(
        panel,
        { scale: 0.92, opacity: 0, y: 20 },
        { scale: 1, opacity: 1, y: 0, duration: 0.45, ease: "back.out(1.4)" }
      );
      gsap.fromTo(backdrop, { opacity: 0 }, { opacity: 1, duration: 0.3 });
    };

    const closeModal = () => {
      gsap.to(panel, {
        scale: 0.92, opacity: 0, y: 20, duration: 0.25, ease: "power2.in",
      });
      gsap.to(backdrop, {
        opacity: 0, duration: 0.25, ease: "power2.in",
        onComplete: () => {
          modal.classList.add("hidden");
          modal.classList.remove("flex");
          document.body.style.overflow = "";
        },
      });
    };

    // Bind buttons
    document.querySelectorAll<HTMLButtonElement>('[data-action="pay"]').forEach((btn) => {
      btn.addEventListener("click", () => {
        const product = btn.dataset.product || "";
        const code = btn.dataset.productCode || product.toUpperCase();
        const priceUsd = Number(btn.dataset.priceUsd || "0");
        openModal(product, code, priceUsd);
      });
    });

    closeBtn?.addEventListener("click", closeModal);
    backdrop?.addEventListener("click", closeModal);
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && !modal.classList.contains("hidden")) closeModal();
    });

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      if (!currentProduct) return;
      hideError();

      const data = new FormData(form);
      const name = String(data.get("name") || "").trim();
      const email = String(data.get("email") || "").trim();

      if (!name || !email) {
        showError("Por favor completá nombre y email.");
        return;
      }

      submitBtn.disabled = true;
      if (submitText) submitText.textContent = "Generando enlace seguro…";
      spinner?.classList.remove("hidden");

      try {
        const res = await fetch("/api/create-payment", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ product: currentProduct, name, email }),
        });
        const result = await res.json();

        if (!res.ok || !result.success) {
          throw new Error(result.error || "No se pudo generar el pago");
        }

        if (summaryBox) {
          summaryBox.innerHTML = `
            <div class="text-center">
              <p class="text-[11px] uppercase tracking-widest text-gray-400 font-bold mb-1">Vas a pagar</p>
              <p class="font-heading text-3xl font-bold text-gradient mb-1">
                AR$ ${Number(result.ars_amount).toLocaleString("es-AR")}
              </p>
              <p class="text-xs text-gray-400">
                ≈ USD ${result.usd_amount} al cambio oficial AR$ ${result.cotizacion} / USD
              </p>
              <p class="text-xs text-accent-cyan mt-2">Redirigiendo a MercadoPago…</p>
            </div>
          `;
          summaryBox.classList.remove("hidden");
        }

        const target = result.init_point || result.sandbox_init_point;
        if (!target) throw new Error("No se recibió enlace de pago");

        setTimeout(() => {
          window.location.href = target;
        }, 1200);
      } catch (err: any) {
        showError(err?.message || "Algo falló. Probá nuevamente o usá la opción WhatsApp.");
        submitBtn.disabled = false;
        if (submitText) submitText.textContent = "Continuar al Pago";
        spinner?.classList.add("hidden");
      }
    });
  };

  initServiciosAnimations();
  initPayModal();

  document.addEventListener("astro:page-load", () => {
    initServiciosAnimations();
    initPayModal();
  });
</script>
