---
const techs = [
  { name: "Python", hoverClass: "hover:text-transparent hover:bg-clip-text hover:bg-linear-to-r hover:from-[#3776AB] hover:from-50% hover:to-[#FFD43B] hover:to-50% transition-all duration-300" },
  { name: "Odoo", hoverClass: "hover:text-[#714B67] transition-colors" },
  { name: "Astro", hoverClass: "hover:text-[#FF5D01] transition-colors" },
  { name: "React", hoverClass: "hover:text-[#61DBFB] transition-colors" },
  { name: "Docker", hoverClass: "hover:text-[#1D63ED] transition-colors" },
  { name: "PostgreSQL", hoverClass: "hover:text-[#336791] transition-colors" },
  { name: "AWS", hoverClass: "hover:text-[#FF9900] transition-colors" },
  { name: "Node.js", hoverClass: "hover:text-[#339933] transition-colors" },
  { name: "Tailwind", hoverClass: "hover:text-[#06B6D4] transition-colors" },
];
// Double the items so each set covers wide viewports
const setItems = [...techs, ...techs];
---

<div class="w-full overflow-hidden relative">
  <!-- Gradient Masks -->
  <div class="absolute top-0 bottom-0 left-0 w-32 z-10 bg-linear-to-r from-dark via-dark/50 to-transparent"></div>
  <div class="absolute top-0 bottom-0 right-0 w-32 z-10 bg-linear-to-l from-dark via-dark/50 to-transparent"></div>

  <div class="py-12 overflow-hidden">
    <div class="flex gap-16 items-center w-max animate-marquee">
      {/* Set A */}
      {setItems.map((t) => (
        <span class={`text-3xl font-bold text-gray-500 ${t.hoverClass} cursor-default shrink-0`}>{t.name}</span>
      ))}
      {/* Set B (identical copy for seamless loop) */}
      {setItems.map((t) => (
        <span class={`text-3xl font-bold text-gray-500 ${t.hoverClass} cursor-default shrink-0`} aria-hidden="true">{t.name}</span>
      ))}
    </div>
  </div>
</div>

<style>
  .animate-marquee {
    animation: marquee 40s linear infinite;
  }

  @keyframes marquee {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }
</style>
