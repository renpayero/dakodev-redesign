---

---

<section
  id="mision-vision-valores"
  aria-labelledby="mvv-heading"
  class="relative overflow-hidden"
>
  <!-- Decorative parallax orbs -->
  <div
    id="mvv-orb-1"
    class="absolute top-1/4 -left-40 w-[500px] h-[500px] bg-accent-cyan/10 rounded-full blur-[100px] z-0 pointer-events-none"
  >
  </div>
  <div
    id="mvv-orb-2"
    class="absolute bottom-1/4 -right-40 w-[500px] h-[500px] bg-accent-teal/10 rounded-full blur-[100px] z-0 pointer-events-none"
  >
  </div>

  <!-- STAGE 1: MISIÓN -->
  <div class="py-32 md:py-40 relative" id="mvv-mision-stage">
    <div class="container mx-auto px-6 relative z-10">
      <span
        class="text-accent-cyan font-bold tracking-widest uppercase text-sm mb-6 block mvv-trigger opacity-0 translate-y-10"
        id="mvv-badge"
      >
        Misión, Visión & Valores
      </span>

      <div class="max-w-5xl" id="mvv-mision-block">
        <h2
          id="mvv-heading"
          class="font-heading text-5xl md:text-7xl lg:text-8xl font-bold mb-8 leading-none mvv-trigger opacity-0 translate-y-10"
        >
          <span class="text-gradient glow-text">MISIÓN</span>
        </h2>

        <p
          id="mvv-mision-text"
          class="text-gray-300 text-xl md:text-2xl lg:text-3xl leading-relaxed font-light max-w-4xl mvv-trigger opacity-0"
          aria-label="Diseñamos e implementamos soluciones de software empresarial para maximizar el potencial de las empresas en crecimiento, con la excelencia de las grandes consultoras a un precio competitivo."
        >
          Diseñamos e implementamos soluciones de software empresarial para
          maximizar el potencial de las empresas en crecimiento, con la
          excelencia de las grandes consultoras a un precio competitivo.
        </p>

        <div
          id="mvv-mision-line"
          class="h-1 bg-gradient-to-r from-accent-cyan to-accent-blue rounded-full mt-8 w-0"
        >
        </div>
      </div>
    </div>
  </div>

  <!-- STAGE 2: VISIÓN -->
  <div class="py-32 md:py-40 relative" id="mvv-vision-stage">
    <div class="container mx-auto px-6 relative z-10">
      <div class="max-w-5xl ml-auto text-right" id="mvv-vision-block">
        <h2
          class="font-heading text-5xl md:text-7xl lg:text-8xl font-bold mb-8 leading-none mvv-trigger opacity-0 translate-y-10"
        >
          <span class="text-gradient glow-text">VISIÓN</span>
        </h2>

        <p
          id="mvv-vision-text"
          class="text-gray-300 text-xl md:text-2xl lg:text-3xl leading-relaxed font-light max-w-4xl ml-auto mvv-trigger opacity-0"
          aria-label="Ser el partner tecnológico de referencia para las empresas y negocios de habla hispana que buscan digitalizar su negocio con tecnología de primer nivel y atención de calidad humana."
        >
          Ser el partner tecnológico de referencia para las empresas y negocios
          de habla hispana que buscan digitalizar su negocio con tecnología de
          primer nivel y atención de calidad humana.
        </p>

        <div
          id="mvv-vision-line"
          class="h-1 bg-gradient-to-r from-accent-blue to-accent-teal rounded-full mt-8 w-0 ml-auto"
        >
        </div>
      </div>
    </div>
  </div>

  <!-- STAGE 3: VALORES -->
  <div class="py-32 md:py-40 relative" id="mvv-valores-stage">
    <div class="container mx-auto px-6 relative z-10">
      <div class="text-center mb-16">
        <h2
          class="font-heading text-5xl md:text-7xl lg:text-8xl font-bold leading-none mvv-trigger opacity-0 scale-75"
          id="mvv-valores-heading"
        >
          <span class="text-gradient glow-text">VALORES</span>
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
        <!-- Valor 1: Comunicación Clara -->
        <div
          class="glass p-8 rounded-3xl border border-white/5 hover:border-accent-cyan/30 transition-all duration-500 mvv-valor-card opacity-0 translate-y-12 group relative"
        >
          <div class="flex items-center gap-4 mb-4">
            <div
              class="w-12 h-12 rounded-xl bg-accent-cyan/10 flex items-center justify-center group-hover:scale-110 transition-transform duration-300"
            >
              <span
                class="text-accent-cyan font-heading font-bold text-xl"
                id="mvv-counter-1">01</span
              >
            </div>
            <h3 class="font-heading text-xl font-bold">Comunicación Clara</h3>
          </div>
          <p class="text-gray-400 leading-relaxed">
            Comunicación clara y compromiso real.
          </p>
        </div>

        <!-- Valor 2: Excelencia Técnica -->
        <div
          class="glass p-8 rounded-3xl border border-white/5 hover:border-accent-blue/30 transition-all duration-500 mvv-valor-card opacity-0 translate-y-12 group relative"
        >
          <div class="flex items-center gap-4 mb-4">
            <div
              class="w-12 h-12 rounded-xl bg-accent-blue/10 flex items-center justify-center group-hover:scale-110 transition-transform duration-300"
            >
              <span
                class="text-accent-blue font-heading font-bold text-xl"
                id="mvv-counter-2">02</span
              >
            </div>
            <h3 class="font-heading text-xl font-bold">Excelencia Técnica</h3>
          </div>
          <p class="text-gray-400 leading-relaxed">
            Trabajo de calidad con excelencia técnica.
          </p>
        </div>

        <!-- Valor 3: Proactividad -->
        <div
          class="glass p-8 rounded-3xl border border-white/5 hover:border-accent-teal/30 transition-all duration-500 mvv-valor-card opacity-0 translate-y-12 group relative"
        >
          <div class="flex items-center gap-4 mb-4">
            <div
              class="w-12 h-12 rounded-xl bg-accent-teal/10 flex items-center justify-center group-hover:scale-110 transition-transform duration-300"
            >
              <span
                class="text-accent-teal font-heading font-bold text-xl"
                id="mvv-counter-3">03</span
              >
            </div>
            <h3 class="font-heading text-xl font-bold">Proactividad</h3>
          </div>
          <p class="text-gray-400 leading-relaxed">
            Anticiparnos a las necesidades y actuar con iniciativa.
          </p>
        </div>

        <!-- Valor 4: Crecimiento Compartido -->
        <div
          class="glass p-8 rounded-3xl border border-white/5 hover:border-accent-cyan/30 transition-all duration-500 mvv-valor-card opacity-0 translate-y-12 group relative"
        >
          <div class="flex items-center gap-4 mb-4">
            <div
              class="w-12 h-12 rounded-xl bg-accent-cyan/10 flex items-center justify-center group-hover:scale-110 transition-transform duration-300"
            >
              <span
                class="text-accent-cyan font-heading font-bold text-xl"
                id="mvv-counter-4">04</span
              >
            </div>
            <h3 class="font-heading text-xl font-bold">
              Crecimiento Compartido
            </h3>
          </div>
          <p class="text-gray-400 leading-relaxed">
            Tu éxito es nuestro éxito. Crecemos juntos.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const initMVVAnimations = () => {
    // Kill only this section's ScrollTriggers
    ScrollTrigger.getAll()
      .filter((st: any) => st.vars?.id?.startsWith("mvv-"))
      .forEach((st) => st.kill());

    // ── PARALLAX: Decorative orbs ──
    gsap.to("#mvv-orb-1", {
      scrollTrigger: {
        id: "mvv-orb1",
        trigger: "#mision-vision-valores",
        start: "top bottom",
        end: "bottom top",
        scrub: 1,
      },
      y: -200,
      x: 100,
      ease: "none",
    });

    gsap.to("#mvv-orb-2", {
      scrollTrigger: {
        id: "mvv-orb2",
        trigger: "#mision-vision-valores",
        start: "top bottom",
        end: "bottom top",
        scrub: 1,
      },
      y: 200,
      x: -100,
      ease: "none",
    });

    // ── STAGE 1: MISIÓN ──

    // Badge
    gsap.to("#mvv-badge", {
      scrollTrigger: {
        id: "mvv-badge",
        trigger: "#mvv-badge",
        start: "top 80%",
        toggleActions: "play none none reverse",
      },
      y: 0,
      opacity: 1,
      duration: 1,
      ease: "power3.out",
    });

    // Mision heading
    gsap.to("#mvv-mision-block h2", {
      scrollTrigger: {
        id: "mvv-mision-h2",
        trigger: "#mvv-mision-block",
        start: "top 80%",
        toggleActions: "play none none reverse",
      },
      y: 0,
      opacity: 1,
      duration: 1.2,
      ease: "power3.out",
    });

    // Mision text: word-by-word stagger reveal
    const misionTextEl = document.getElementById("mvv-mision-text");
    if (misionTextEl && !misionTextEl.dataset.split) {
      const originalText = misionTextEl.textContent || "";
      const words = originalText.trim().split(/\s+/);
      misionTextEl.innerHTML = words
        .map(
          (w) =>
            `<span class="mvv-mision-word inline-block opacity-0 translate-y-4">${w}&nbsp;</span>`,
        )
        .join("");
      misionTextEl.dataset.split = "true";
    }

    gsap.to(".mvv-mision-word", {
      scrollTrigger: {
        id: "mvv-mision-words",
        trigger: "#mvv-mision-text",
        start: "top 80%",
        toggleActions: "play none none reverse",
      },
      y: 0,
      opacity: 1,
      duration: 0.6,
      stagger: 0.04,
      ease: "power2.out",
    });

    // Mision accent line
    gsap.to("#mvv-mision-line", {
      scrollTrigger: {
        id: "mvv-mision-line",
        trigger: "#mvv-mision-line",
        start: "top 85%",
        toggleActions: "play none none reverse",
      },
      width: "100%",
      duration: 1.5,
      ease: "power2.inOut",
    });

    // ── STAGE 2: VISIÓN ──

    // Vision heading
    gsap.to("#mvv-vision-block h2", {
      scrollTrigger: {
        id: "mvv-vision-h2",
        trigger: "#mvv-vision-block",
        start: "top 80%",
        toggleActions: "play none none reverse",
      },
      y: 0,
      opacity: 1,
      duration: 1.2,
      ease: "power3.out",
    });

    // Vision text: word-by-word stagger reveal
    const visionTextEl = document.getElementById("mvv-vision-text");
    if (visionTextEl && !visionTextEl.dataset.split) {
      const originalText = visionTextEl.textContent || "";
      const words = originalText.trim().split(/\s+/);
      visionTextEl.innerHTML = words
        .map(
          (w) =>
            `<span class="mvv-vision-word inline-block opacity-0 translate-y-4">${w}&nbsp;</span>`,
        )
        .join("");
      visionTextEl.dataset.split = "true";
    }

    gsap.to(".mvv-vision-word", {
      scrollTrigger: {
        id: "mvv-vision-words",
        trigger: "#mvv-vision-text",
        start: "top 80%",
        toggleActions: "play none none reverse",
      },
      y: 0,
      opacity: 1,
      duration: 0.6,
      stagger: 0.04,
      ease: "power2.out",
    });

    // Vision accent line
    gsap.to("#mvv-vision-line", {
      scrollTrigger: {
        id: "mvv-vision-line",
        trigger: "#mvv-vision-line",
        start: "top 85%",
        toggleActions: "play none none reverse",
      },
      width: "60%",
      duration: 1.5,
      ease: "power2.inOut",
    });

    // ── STAGE 3: VALORES ──

    // Valores heading: scale-up
    gsap.to("#mvv-valores-heading", {
      scrollTrigger: {
        id: "mvv-valores-heading",
        trigger: "#mvv-valores-heading",
        start: "top 80%",
        toggleActions: "play none none reverse",
      },
      scale: 1,
      opacity: 1,
      duration: 1.2,
      ease: "back.out(1.4)",
    });

    // Value cards: staggered bounce-in
    gsap.utils.toArray(".mvv-valor-card").forEach((card: any, i) => {
      gsap.to(card, {
        scrollTrigger: {
          id: `mvv-card-${i}`,
          trigger: card,
          start: "top 85%",
          toggleActions: "play none none reverse",
        },
        y: 0,
        opacity: 1,
        duration: 0.8,
        delay: i * 0.15,
        ease: "back.out(1.7)",
      });
    });

    // Counter number scramble effect (like Loader)
    const counterIds = [
      "mvv-counter-1",
      "mvv-counter-2",
      "mvv-counter-3",
      "mvv-counter-4",
    ];
    const counterFinals = ["01", "02", "03", "04"];
    const scrambleChars = "0123456789!@#$%";

    counterIds.forEach((id, i) => {
      const el = document.getElementById(id);
      if (!el) return;

      ScrollTrigger.create({
        id: `mvv-counter-${i}`,
        trigger: el,
        start: "top 85%",
        onEnter: () => {
          let iterations = 0;
          const maxIterations = 30;
          const interval = setInterval(() => {
            el.textContent = counterFinals[i]
              .split("")
              .map((char, idx) => {
                if (
                  idx <
                  iterations / (maxIterations / counterFinals[i].length)
                ) {
                  return counterFinals[i][idx];
                }
                return scrambleChars[
                  Math.floor(Math.random() * scrambleChars.length)
                ];
              })
              .join("");
            if (iterations >= maxIterations) {
              clearInterval(interval);
              el.textContent = counterFinals[i];
            }
            iterations++;
          }, 1000 / 30);
        },
        onLeaveBack: () => {
          el.textContent = counterFinals[i];
        },
      });
    });
  };

  // Run on initial load
  initMVVAnimations();

  // Re-run after View Transition page swaps
  document.addEventListener("astro:page-load", initMVVAnimations);
</script>
